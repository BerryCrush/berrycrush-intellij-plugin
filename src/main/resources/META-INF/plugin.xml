<idea-plugin>
    <id>com.berrycrush.intellij</id>
    <name>BerryCrush</name>
    <vendor email="support@berrycrush.org" url="https://github.com/berrycrush/berrycrush">BerryCrush</vendor>

    <description><![CDATA[
    <h2>BerryCrush - OpenAPI-Driven BDD Testing</h2>
    <p>Language support for BerryCrush <code>.scenario</code> and <code>.fragment</code> files.</p>

    <h3>Features</h3>
    <ul>
        <li>Syntax highlighting for BerryCrush DSL</li>
        <li>Code completion for keywords and directives</li>
        <li>Code folding for features, scenarios, and steps</li>
        <li>Structure view navigation</li>
        <li>Navigate from include directives to fragment files</li>
        <li>Navigate from operation references to OpenAPI specs</li>
        <li>Gutter icons for quick navigation</li>
        <li>Find Usages support</li>
        <li>Custom file icons</li>
    </ul>

    <h3>File Types</h3>
    <ul>
        <li><strong>.scenario</strong> - Test scenario files</li>
        <li><strong>.fragment</strong> - Reusable step fragments</li>
    </ul>
    ]]></description>

    <change-notes><![CDATA[
    <h3>1.0.0</h3>
    <ul>
        <li>Initial release</li>
        <li>Syntax highlighting</li>
        <li>Basic code completion</li>
        <li>Code folding</li>
        <li>Structure view</li>
    </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File Change Listener for inspection auto-refresh -->
        <vfs.asyncListener implementation="com.berrycrush.intellij.listener.BerryCrushFileChangeListener"/>

        <!-- File-based Indices for fast lookup -->
        <fileBasedIndex implementation="com.berrycrush.intellij.index.FragmentIndex"/>
        <fileBasedIndex implementation="com.berrycrush.intellij.index.OperationUsageIndex"/>
        <fileBasedIndex implementation="com.berrycrush.intellij.index.IncludeUsageIndex"/>
        <fileBasedIndex implementation="com.berrycrush.intellij.index.StepUsageIndex"/>

        <!-- File Types -->
        <fileType name="BerryCrush Scenario"
                  implementationClass="com.berrycrush.intellij.language.ScenarioFileType"
                  fieldName="INSTANCE"
                  language="BerryCrush"
                  extensions="scenario"/>

        <fileType name="BerryCrush Fragment"
                  implementationClass="com.berrycrush.intellij.language.FragmentFileType"
                  fieldName="INSTANCE"
                  language="BerryCrush"
                  extensions="fragment"/>

        <!-- Language -->
        <lang.parserDefinition language="BerryCrush"
                               implementationClass="com.berrycrush.intellij.parser.BerryCrushParserDefinition"/>

        <!-- Syntax Highlighting -->
        <lang.syntaxHighlighterFactory language="BerryCrush"
                                       implementationClass="com.berrycrush.intellij.highlighting.BerryCrushSyntaxHighlighterFactory"/>

        <colorSettingsPage implementation="com.berrycrush.intellij.highlighting.BerryCrushColorSettingsPage"/>

        <!-- Code Folding -->
        <lang.foldingBuilder language="BerryCrush"
                             implementationClass="com.berrycrush.intellij.folding.BerryCrushFoldingBuilder"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory language="BerryCrush"
                                      implementationClass="com.berrycrush.intellij.structure.BerryCrushStructureViewFactory"/>

        <!-- Breadcrumbs -->
        <breadcrumbsInfoProvider implementation="com.berrycrush.intellij.navigation.BerryCrushBreadcrumbsProvider"/>

        <!-- Completion -->
        <completion.contributor language="BerryCrush"
                                implementationClass="com.berrycrush.intellij.completion.BerryCrushCompletionContributor"/>

        <!-- Commenter -->
        <lang.commenter language="BerryCrush"
                        implementationClass="com.berrycrush.intellij.commenter.BerryCrushCommenter"/>

        <!-- Brace Matcher -->
        <lang.braceMatcher language="BerryCrush"
                           implementationClass="com.berrycrush.intellij.highlighting.BerryCrushBraceMatcher"/>

        <!-- References for BerryCrush files -->
        <psi.referenceContributor
                                  implementation="com.berrycrush.intellij.reference.BerryCrushReferenceContributor"/>

        <!-- References for @Step/@Assertion annotation strings (Java) -->
        <psi.referenceContributor language="JAVA"
                                  implementation="com.berrycrush.intellij.reference.JavaAnnotationStringReferenceContributor"/>

        <!-- References for @Step/@Assertion annotation strings (Kotlin) -->
        <psi.referenceContributor language="kotlin"
                                  implementation="com.berrycrush.intellij.reference.KotlinAnnotationStringReferenceContributor"/>

        <!-- Navigation -->
        <codeInsight.lineMarkerProvider language="BerryCrush"
                                        implementationClass="com.berrycrush.intellij.navigation.BerryCrushLineMarkerProvider"/>

        <!-- Line Marker for @Step/@Assertion usages (Java and Kotlin via light PSI) -->
        <codeInsight.lineMarkerProvider language="JAVA"
                                        implementationClass="com.berrycrush.intellij.navigation.StepAnnotationLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="kotlin"
                                        implementationClass="com.berrycrush.intellij.navigation.StepAnnotationLineMarkerProvider"/>

        <!-- Go to Declaration -->
        <gotoDeclarationHandler
                                implementation="com.berrycrush.intellij.navigation.BerryCrushGotoDeclarationHandler"/>

        <!-- Find Usages -->
        <lang.findUsagesProvider language="BerryCrush"
                                 implementationClass="com.berrycrush.intellij.navigation.BerryCrushFindUsagesProvider"/>

        <!-- Run Configuration -->
        <configurationType implementation="com.berrycrush.intellij.run.BerryCrushConfigurationType"/>

        <!-- Run Configuration Producer (creates configs from context) -->
        <runConfigurationProducer implementation="com.berrycrush.intellij.run.BerryCrushRunConfigurationProducer"/>

        <!-- Run Line Markers (gutter run icons) -->
        <runLineMarkerContributor language="BerryCrush"
                                  implementationClass="com.berrycrush.intellij.run.BerryCrushRunLineMarkerProvider"/>

        <!-- Inspections (no language attr - checks in implementation) -->
        <localInspection groupName="BerryCrush"
                         shortName="BerryCrushMissingFragment"
                         displayName="Missing fragment reference"
                         enabledByDefault="true"
                         level="ERROR"
                         implementationClass="com.berrycrush.intellij.inspection.MissingFragmentInspection"/>

        <localInspection groupName="BerryCrush"
                         shortName="BerryCrushUndefinedOperation"
                         displayName="Undefined OpenAPI operation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.berrycrush.intellij.inspection.UndefinedOperationInspection"/>

        <localInspection groupName="BerryCrush"
                         shortName="BerryCrushUndefinedStep"
                         displayName="Undefined custom step"
                         enabledByDefault="true"
                         level="WEAK WARNING"
                         implementationClass="com.berrycrush.intellij.inspection.UndefinedStepInspection"/>

        <localInspection groupName="BerryCrush"
                         shortName="BerryCrushUndefinedAssertion"
                         displayName="Undefined assertion"
                         enabledByDefault="true"
                         level="WEAK WARNING"
                         implementationClass="com.berrycrush.intellij.inspection.UndefinedAssertionInspection"/>

        <!-- Refactoring Support -->
        <lang.refactoringSupport language="BerryCrush"
                                 implementationClass="com.berrycrush.intellij.refactoring.BerryCrushRefactoringSupportProvider"/>

        <renameHandler implementation="com.berrycrush.intellij.refactoring.BerryCrushRenameHandler"/>

        <renamePsiElementProcessor
                implementation="com.berrycrush.intellij.refactoring.fragment.FragmentRenameProcessor"/>

        <renamePsiElementProcessor
                implementation="com.berrycrush.intellij.refactoring.variable.VariableRenameProcessor"/>

        <refactoring.safeDeleteProcessor
                implementation="com.berrycrush.intellij.refactoring.safedelete.BerryCrushSafeDeleteProcessor"/>

        <!-- Target Element Evaluator for finding elements at caret position -->
        <targetElementEvaluator language="BerryCrush"
                implementationClass="com.berrycrush.intellij.navigation.BerryCrushTargetElementEvaluator"/>
    </extensions>

    <actions>
        <!-- Actions removed - native Safe Delete now works for fragments -->
    </actions>
</idea-plugin>
