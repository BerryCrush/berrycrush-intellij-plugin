<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude generated code -->
    <Match>
        <Package name="~.*\.generated\..*"/>
    </Match>
    
    <!-- Exclude test classes -->
    <Match>
        <Source name="~.*Test\.kt"/>
    </Match>
    
    <!-- Exclude test directories -->
    <Match>
        <Package name="~.*\.test\..*"/>
    </Match>

    <!-- IntelliJ Platform API patterns - returning arrays is expected -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>
    
    <!-- Kotlin data classes and singletons -->
    <Match>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    
    <!-- Dead store to local variable - common in Kotlin -->
    <Match>
        <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
    </Match>
    
    <!-- Return value ignored - common in builder patterns -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
    </Match>
    
    <!-- Redundant null check - Kotlin already handles this -->
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>
    <Match>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_WOULD_HAVE_BEEN_A_NPE"/>
    </Match>
    
    <!-- Kotlin when expressions with else branch compiled to switch without default -->
    <Match>
        <Bug pattern="SF_SWITCH_NO_DEFAULT"/>
    </Match>
    
    <!-- IntelliJ CustomCodeStyleSettings extends class with equals() but manages its own state -->
    <Match>
        <Class name="com.berrycrush.intellij.codestyle.BerryCrushCodeStyleSettings"/>
        <Bug pattern="HE_INHERITS_EQUALS_USE_HASHCODE"/>
    </Match>
    
    <!-- Bad cast to abstract collection - common with Kotlin collections -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>
    
    <!-- Duplicate branches - can occur in when expressions -->
    <Match>
        <Bug pattern="DB_DUPLICATE_BRANCHES"/>
    </Match>
    
    <!-- Catch generic Exception - intentional for defensive coding in IDE plugins -->
    <Match>
        <Bug pattern="REC_CATCH_EXCEPTION"/>
    </Match>
    
    <!-- Nullness annotation tightening - Kotlin classes use non-null by default -->
    <Match>
        <Bug pattern="NP_METHOD_PARAMETER_TIGHTENS_ANNOTATION"/>
    </Match>
    
    <!-- File.delete()/mkdirs() return values - best-effort cleanup operations -->
    <Match>
        <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
        <Class name="com.berrycrush.intellij.run.TemporaryTestGenerator"/>
    </Match>
</FindBugsFilter>
